{
  "permissions": {
    "allow": [
      "Bash(./tools/gen-code-from-swagger.sh:*)",
      "Bash(golangci-lint:*)",
      "Bash(./tools/linter_go_routines.sh:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx block-no-verify@1.1.2"
          }
        ]
      }
    ]
  }
}
